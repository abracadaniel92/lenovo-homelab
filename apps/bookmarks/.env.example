# Copy to .env and set on the server (e.g. /mnt/ssd/apps/bookmarks/.env)
# MATTERMOST_WEBHOOK_URL=https://mattermost.gmojsoski.com/hooks/xxxxx
# BOOKMARKS_SECRET_TOKEN=your_secret_token

# Optional: use SLACK_WEBHOOK_URL if you use Slack instead of Mattermost
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx
